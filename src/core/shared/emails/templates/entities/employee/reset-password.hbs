{{> header}}
    <div class="audience-card">
    <div class="header-audience">
        <h1>🔐 Réinitialisation de votre mot de passe</h1>
    </div>

    <p>Bonjour <strong>{{user.first_name}} {{user.last_name}}</strong>,</p>
    <p>Vous avez demandé la réinitialisation de votre mot de passe.</p>

    <div class="info-section">
        <h2>📋 Détails de la demande</h2>
        <table class="info-table">
        <tr>
            <td><strong>Demande effectuée le :</strong></td>
            <td>{{requestDate}}</td>
        </tr>
        <tr>
            <td><strong>Lien valable jusqu'au :</strong></td>
            <td>{{resetPasswordExpiration}}</td>
        </tr>
        </table>
    </div>

    <div class="actions-section">
        <a href="{{resetLink}}" class="btn btn-primary">Réinitialiser mon mot de passe</a>
        <p style="margin-top: 20px; font-size: 14px; color: #6b7280;">
        Ce lien expire dans {{resetPasswordHoursRemaining}} heures.
        </p>
    </div>
    </div>
{{> footer}}
