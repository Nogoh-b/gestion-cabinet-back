
{{> header}}

  <div class="audience-card">
    <div class="header-audience">
      <h1>🎉 Bienvenue dans l'équipe {{branch.name}} !</h1>
      <div class="badge upcoming">Nouveau collaborateur</div>
    </div>

    <p>Bonjour <strong>{{user.first_name}} {{user.last_name}}</strong>,</p>
    <p>Votre compte a été créé avec succès sur la plateforme du Cabinet Juridique.</p>

    <div class="info-section">
      <h2>🔑 Vos identifiants de connexion</h2>
      <table class="info-table">
        <tr>
          <td><strong>Email :</strong></td>
          <td>{{user.email}}</td>
        </tr>
        <tr>
          <td><strong>Mot de passe temporaire :</strong></td>
          <td><code style="background: #f1f5f9; padding: 6px 12px; border-radius: 4px; font-size: 16px;">{{tempPassword}}</code></td>
        </tr>
      </table>
    </div>

    <div class="info-section">
      <h2>📋 Récapitulatif de votre profil</h2>
      <table class="info-table">
        <tr>
          <td><strong>Fonction :</strong></td>
          <td>{{position}}</td>
        </tr>
        <tr>
          <td><strong>Spécialisation :</strong></td>
          <td>{{specialization}}</td>
        </tr>
        <tr>
          <td><strong>Numéro de barreau :</strong></td>
          <td>{{bar_association_number}} - {{bar_association_city}}</td>
        </tr>
        <tr>
          <td><strong>Taux horaire :</strong></td>
          <td>{{hourly_rate}} €</td>
        </tr>
        <tr>
          <td><strong>Téléphone professionnel :</strong></td>
          <td>{{professional_phone}}</td>
        </tr>
        <tr>
          <td><strong>Adresse professionnelle :</strong></td>
          <td>{{professional_address}}</td>
        </tr>
        <tr>
          <td><strong>Numéro SIRET :</strong></td>
          <td>{{siret_number}}</td>
        </tr>
        <tr>
          <td><strong>N° TVA :</strong></td>
          <td>{{tva_number}}</td>
        </tr>
      </table>
    </div>

    {{#if bio}}
    <div class="info-section">
      <h2>📝 Biographie</h2>
      <p class="notes">{{bio}}</p>
    </div>
    {{/if}}

    <div class="actions-section">
      <h3>🔗 Pour vous connecter :</h3>
      <a href="{{loginLink}}" class="btn btn-primary">Accéder à mon espace</a>
    </div>

    <p style="margin-top: 20px; font-size: 14px; color: #6b7280; background-color: #fff3e0; padding: 10px; border-radius: 6px;">
      <strong>🔒 Sécurité :</strong> Pour des raisons de sécurité, nous vous recommandons de changer votre mot de passe dès votre première connexion.
    </p>
  </div>
{{> footer}}

