<!-- templates/auth/otp-reset-password.hbs -->
<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Code de réinitialisation</title>
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333;">
  <div style="max-width: 600px; margin: 0 auto; padding: 20px;">
    <div style="text-align: center; margin-bottom: 30px;">
      <h1 style="color: #4F46E5;">LexiGuard</h1>
    </div>
    
    <div style="background-color: #f9f9f9; padding: 30px; border-radius: 10px;">
      <h2>Bonjour {{userName}},</h2>
      
      <p>Vous avez demandé la réinitialisation de votre mot de passe. Voici votre code de vérification :</p>
      
      <div style="text-align: center; margin: 30px 0;">
        <div style="font-size: 32px; font-weight: bold; letter-spacing: 5px; background-color: #fff; padding: 15px; border-radius: 8px; border: 1px solid #e0e0e0;">
          {{otp}}
        </div>
      </div>
      
      <p>Ce code est valable pendant <strong>{{expiresIn}} minutes</strong>.</p>
      
      <p>Si vous n'avez pas demandé cette réinitialisation, ignorez simplement cet email.</p>
      
      <hr style="margin: 30px 0; border: none; border-top: 1px solid #e0e0e0;">
      
      <p style="font-size: 12px; color: #666;">
        LexiGuard - Cabinet d'Avocats<br>
        Ceci est un email automatique, merci de ne pas y répondre.
      </p>
    </div>
  </div>
</body>
</html>