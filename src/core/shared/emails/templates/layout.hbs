<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        /* Styles globaux */
        body { font-family: Arial, sans-serif; margin: 0; padding: 0; }
        .header { background-color: #f8f9fa; padding: 20px; text-align: center; }
        .footer { background-color: #f8f9fa; padding: 20px; text-align: center; margin-top: 20px; }
        .logo { max-width: 150px; margin-bottom: 10px; }
    </style>
</head>
<body>
    <div class="header">
        {{#if logoUrl}}
            <img src="{{logoUrl}}" alt="{{companyName}}" class="logo">
        {{/if}}
        <div>{{companyName}}</div>
        <div>{{companyAddress}}</div>
    </div>

    <div class="content">
        {{{body}}} <!-- Le contenu spécifique du template sera injecté ici -->
    </div>

    <div class="footer">
        <p>{{companyName}} - {{companyAddress}}</p>
        <p>Email : {{companyEmail}} | Tél : {{companyPhone}}</p>
        <p>&copy; {{currentYear}} {{companyName}}. Tous droits réservés.</p>
    </div>
</body>
</html>